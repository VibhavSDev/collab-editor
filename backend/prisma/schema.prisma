// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

// This is your database connection
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  password      String
  name          String
  documents     Document[]     @relation("Owner")
  collaborations Collaboration[]
  comments      Comment[]
  createdAt     DateTime       @default(now())
}

model Document {
  id             String          @id @default(uuid())
  title          String          @default("Untitled Document")
  content        Bytes?          // We store Yjs binary updates here for efficiency
  ownerId        String
  owner          User            @relation("Owner", fields: [ownerId], references: [id])
  collaborators  Collaboration[]
  versions       Version[]
  comments       Comment[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model Collaboration {
  id         String   @id @default(uuid())
  role       Role     @default(VIEWER) // VIEWER, EDITOR, ADMIN
  userId     String
  documentId String
  user       User     @relation(fields: [userId], references: [id])
  document   Document @relation(fields: [documentId], references: [id])

  @@unique([userId, documentId]) // A user can only have one role per document
}

enum Role {
  VIEWER
  EDITOR
  ADMIN
}

model Version {
  id         String   @id @default(uuid())
  content    Bytes    // Snapshot of the document at that time
  documentId String
  document   Document @relation(fields: [documentId], references: [id])
  createdAt  DateTime @default(now())
}

model Comment {
  id         String   @id @default(uuid())
  text       String
  position   String   // Stores the TipTap node position/index
  userId     String
  documentId String
  user       User     @relation(fields: [userId], references: [id])
  document   Document @relation(fields: [documentId], references: [id])
  createdAt  DateTime @default(now())
}